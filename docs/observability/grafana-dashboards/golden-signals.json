{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus 데이터소스",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "MSA 티켓팅 시스템 — 서비스별 Golden Signals (RPS / Error Rate / Latency / JVM / HikariCP / CircuitBreaker)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100, "title": "🚦 HTTP Traffic — Golden Signals", "type": "row" },

    {
      "id": 1, "title": "RPS (req/s)",
      "description": "초당 요청 수. 서비스에 실제로 트래픽이 들어오는지 확인하는 가장 기본 지표.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 500 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(rate(http_server_requests_seconds_count{application=\"$service\"}[$interval]))",
        "legendFormat": "RPS", "refId": "A"
      }]
    },

    {
      "id": 2, "title": "Error Rate (%)",
      "description": "5xx 에러 비율. 1% 이하 유지가 목표 (SLO 기준).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(rate(http_server_requests_seconds_count{application=\"$service\",status=~\"5..\"}[$interval])) / sum(rate(http_server_requests_seconds_count{application=\"$service\"}[$interval])) * 100",
        "legendFormat": "Error Rate", "refId": "A"
      }]
    },

    {
      "id": 3, "title": "Latency p95 (ms)",
      "description": "95번째 백분위 응답시간. Spring Boot percentiles-histogram 활성화 서비스만 표시됨.\n미표시 서비스(user/scg): application.yml에 management.metrics.distribution.percentiles-histogram.http.server.requests=true 추가 필요.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 200 },
            { "color": "red", "value": 500 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"$service\"}[$interval]))) * 1000",
        "legendFormat": "p95", "refId": "A"
      }]
    },

    {
      "id": 4, "title": "Latency p99 (ms)",
      "description": "99번째 백분위 응답시간. 꼬리 레이턴시(tail latency) 지표.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 500 },
            { "color": "red", "value": 1000 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"$service\"}[$interval]))) * 1000",
        "legendFormat": "p99", "refId": "A"
      }]
    },

    {
      "id": 5, "title": "Active Requests",
      "description": "현재 처리 중인 동시 요청 수.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 100 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(http_server_requests_active_seconds_active_count{application=\"$service\"})",
        "legendFormat": "Active", "refId": "A"
      }]
    },

    {
      "id": 6, "title": "Outcome 분포",
      "description": "SUCCESS / CLIENT_ERROR / SERVER_ERROR 비율 시각화. 4xx와 5xx를 분리해서 클라이언트 오류와 서버 오류를 구분한다.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "SERVER_ERROR" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "CLIENT_ERROR" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "SUCCESS" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "vertical", "textMode": "auto", "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum by (outcome) (rate(http_server_requests_seconds_count{application=\"$service\"}[$interval]))",
        "legendFormat": "{{outcome}}", "refId": "A"
      }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101, "title": "📈 Latency 추이", "type": "row" },

    {
      "id": 7, "title": "Latency 백분위 추이 (p50 / p95 / p99)",
      "description": "ADR: p95 < 500ms 를 SLO 기준으로 설정. 부하테스트 시 이 그래프에서 임계점(knee point)이 보이면ㅁ 병목 구간 식별 근거로 활용.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"$service\"}[$interval]))) * 1000",
          "legendFormat": "p50", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"$service\"}[$interval]))) * 1000",
          "legendFormat": "p95", "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"$service\"}[$interval]))) * 1000",
          "legendFormat": "p99", "refId": "C"
        }
      ]
    },

    {
      "id": 8, "title": "URI별 p99 Top 10 (Slow Endpoints)",
      "description": "가장 느린 엔드포인트 Top 10. 병목 구간 식별의 핵심 패널. k6 부하테스트 후 여기서 개선 대상 URI를 선정한다.",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "uri" }, "properties": [{ "id": "custom.width", "value": 300 }] },
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [
            { "id": "displayName", "value": "p99 (ms)" },
            { "id": "custom.displayMode", "value": "color-background" },
            { "id": "thresholds", "value": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]}}
          ]}
        ]
      },
      "options": { "sortBy": [{ "desc": true, "displayName": "p99 (ms)" }] },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "topk(10, histogram_quantile(0.99, sum by (uri, le) (rate(http_server_requests_seconds_bucket{application=\"$service\"}[$interval]))) * 1000)",
        "instant": true,
        "legendFormat": "{{uri}}", "refId": "A",
        "format": "table"
      }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102, "title": "☕ JVM", "type": "row" },

    {
      "id": 9, "title": "JVM Heap 사용률 (%)",
      "description": "힙 메모리 사용률. 80% 이상이면 GC 압박이 시작되고, 부하테스트 중 OOM 위험 구간.",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 85 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(jvm_memory_used_bytes{application=\"$service\", area=\"heap\"}) / sum(jvm_memory_max_bytes{application=\"$service\", area=\"heap\"}) * 100",
        "legendFormat": "Heap %", "refId": "A"
      }]
    },

    {
      "id": 10, "title": "JVM Heap 사용량 추이",
      "description": "Used / Committed / Max 세 가지를 함께 표시. Used가 Max에 근접하면 GC 폭증의 전조.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 10, "x": 6, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(jvm_memory_used_bytes{application=\"$service\", area=\"heap\"})",
          "legendFormat": "Used", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(jvm_memory_committed_bytes{application=\"$service\", area=\"heap\"})",
          "legendFormat": "Committed", "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(jvm_memory_max_bytes{application=\"$service\", area=\"heap\"})",
          "legendFormat": "Max", "refId": "C"
        }
      ]
    },

    {
      "id": 11, "title": "GC Pause 시간 (rate)",
      "description": "초당 GC pause 시간. 부하 증가 시 급격히 올라가면 힙 부족 또는 객체 할당률 과다 신호.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 1 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum by (action) (rate(jvm_gc_pause_seconds_sum{application=\"$service\"}[$interval]))",
        "legendFormat": "{{action}}", "refId": "A"
      }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "id": 103, "title": "🗄️ Database (HikariCP)", "type": "row" },

    {
      "id": 12, "title": "HikariCP 커넥션 상태",
      "description": "Active: 현재 SQL 실행 중 / Idle: 대기 중 / Pending: 커넥션 풀 고갈로 대기 중인 스레드. Pending > 0이면 DB 병목 신호.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Pending" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Active" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Idle" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "hikaricp_connections_active{application=\"$service\"}",
          "legendFormat": "Active", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "hikaricp_connections_idle{application=\"$service\"}",
          "legendFormat": "Idle", "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "hikaricp_connections_pending{application=\"$service\"}",
          "legendFormat": "Pending", "refId": "C"
        }
      ]
    },

    {
      "id": 13, "title": "HikariCP 풀 사용률 (%)",
      "description": "active / max 비율. 100%는 풀 고갈 상태를 의미 — 이때부터 Pending 스레드가 쌓이기 시작한다.",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 80 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "hikaricp_connections_active{application=\"$service\"} / hikaricp_connections_max{application=\"$service\"} * 100",
        "legendFormat": "Pool 사용률", "refId": "A"
      }]
    },

    {
      "id": 14, "title": "HikariCP 커넥션 획득 시간 p99 (ms)",
      "description": "DB 커넥션을 획득하는 데 걸리는 시간. 풀이 고갈될수록 이 값이 급등한다.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 500 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "histogram_quantile(0.99, sum by (le) (rate(hikaricp_connections_acquire_seconds_bucket{application=\"$service\"}[$interval]))) * 1000",
        "legendFormat": "Acquire p99", "refId": "A"
      }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "id": 104, "title": "⚡ CircuitBreaker (SCG Gateway)", "type": "row" },

    {
      "id": 15, "title": "CB State (scg-service)",
      "description": "SCG의 4개 CircuitBreaker(booking/concert/payment/user) 상태 추이.\nstate=1이 CLOSED(정상), 0이 OPEN(차단)/HALF_OPEN(복구 시도). OPEN 상태 지속 시 Saga 보상 트랜잭션 트리거 여부 확인 필요.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 }, "min": 0, "max": 1 }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "resilience4j_circuitbreaker_state{application=\"scg-service\", state=\"closed\"}",
        "legendFormat": "{{name}} CLOSED", "refId": "A"
      },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "resilience4j_circuitbreaker_state{application=\"scg-service\", state=\"open\"}",
        "legendFormat": "{{name}} OPEN", "refId": "B"
      }]
    },

    {
      "id": 16, "title": "CB 호출 성공/실패율",
      "description": "CircuitBreaker를 통과한 요청의 성공률. failureRateThreshold(50%)에 도달하면 CB가 OPEN으로 전환됨.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
